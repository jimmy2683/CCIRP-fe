# ================================

# Next.js / React .gitignore

# ================================

# dependencies

/node_modules

# Yarn / PnP

/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing

/coverage

# Next.js build output

/.next/
/out/

# production build

/build

# environment variables

.env*
!.env.example

# Vercel deployment files

.vercel

# logs

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files

.DS_Store
Thumbs.db

# certificates

*.pem

# TypeScript

*.tsbuildinfo
next-env.d.ts
